{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "DeepAudit Intelligence Platform - API, Worker, PostgreSQL, Redis"
  },
  "parameters": {
    "environmentName": {
      "type": "string",
      "defaultValue": "deepaudit-prod",
      "metadata": { "description": "Environment identifier" }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Azure region" }
    },
    "dbAdminLogin": {
      "type": "string",
      "defaultValue": "deepaudit",
      "metadata": { "description": "PostgreSQL admin username" }
    },
    "dbAdminPassword": {
      "type": "secureString",
      "metadata": { "description": "PostgreSQL admin password (min 8 chars)" }
    },
    "dbName": {
      "type": "string",
      "defaultValue": "deepaudit",
      "metadata": { "description": "Database name" }
    },
    "openAiApiKey": {
      "type": "secureString",
      "metadata": { "description": "OpenAI API key" }
    },
    "postgresSku": {
      "type": "string",
      "defaultValue": "B_Standard_B1ms",
      "allowedValues": ["B_Standard_B1ms", "B_Standard_B2s", "GP_Standard_D2s_v3"],
      "metadata": { "description": "PostgreSQL SKU" }
    },
    "redisSku": {
      "type": "string",
      "defaultValue": "Basic",
      "allowedValues": ["Basic", "Standard"],
      "metadata": { "description": "Redis SKU" }
    },
    "containerCpu": {
      "type": "string",
      "defaultValue": "0.5",
      "allowedValues": ["0.25", "0.5", "0.75", "1.0"],
      "metadata": { "description": "Container CPU cores" }
    },
    "containerMemory": {
      "type": "string",
      "defaultValue": "1Gi",
      "allowedValues": ["0.5Gi", "1Gi", "1.5Gi", "2Gi"],
      "metadata": { "description": "Container memory" }
    }
  },
  "variables": {
    "acrName": "[replace(concat(parameters('environmentName'), 'acr'), '-', '')]",
    "acaEnvName": "[concat(parameters('environmentName'), '-env')]",
    "apiAppName": "[concat(parameters('environmentName'), '-api')]",
    "workerAppName": "[concat(parameters('environmentName'), '-worker')]",
    "postgresServerName": "[replace(concat(parameters('environmentName'), '-pg'), '-', '')]",
    "redisName": "[replace(concat(parameters('environmentName'), '-redis'), '-', '')]",
    "logAnalyticsName": "[concat(parameters('environmentName'), '-logs')]",
    "vnetName": "[concat(parameters('environmentName'), '-vnet')]",
    "subnetName": "aca-subnet"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": { "name": "PerGB2018" },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-05-01",
      "name": "[variables('vnetName')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": { "addressPrefixes": ["10.0.0.0/16"] },
        "subnets": [{
          "name": "[variables('subnetName')]",
          "properties": {
            "addressPrefix": "10.0.1.0/24",
            "delegations": [{
              "name": "aca-delegation",
              "properties": {
                "serviceName": "Microsoft.App/environments"
              }
            }]
          }
        }]
      }
    },
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[variables('acrName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Basic" },
      "properties": { "adminUserEnabled": true }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers",
      "apiVersion": "2023-03-01-preview",
      "name": "[variables('postgresServerName')]",
      "location": "[parameters('location')]",
      "properties": {
        "version": "15",
        "administratorLogin": "[parameters('dbAdminLogin')]",
        "administratorLoginPassword": "[parameters('dbAdminPassword')]",
        "storage": { "storageSizeGB": 32 },
        "backup": { "backupRetentionDays": 7, "geoRedundantBackup": "Disabled" },
        "highAvailability": { "mode": "Disabled" },
        "network": {
          "publicNetworkAccess": "Enabled"
        }
      },
      "sku": {
        "name": "[parameters('postgresSku')]",
        "tier": "Burstable"
      }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/firewallRules",
      "apiVersion": "2023-03-01-preview",
      "name": "[concat(variables('postgresServerName'), '/AllowAll')]",
      "dependsOn": ["[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]"],
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "255.255.255.255"
      }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2023-03-01-preview",
      "name": "[concat(variables('postgresServerName'), '/', parameters('dbName'))]",
      "dependsOn": ["[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]"],
      "properties": {}
    },
    {
      "type": "Microsoft.Cache/redis",
      "apiVersion": "2023-08-01",
      "name": "[variables('redisName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "[parameters('redisSku')]",
          "family": "C",
          "capacity": "[if(equals(parameters('redisSku'), 'Basic'), 0, 1)]"
        },
        "enableNonSslPort": false,
        "minimumTlsVersion": "1.2",
        "redisConfiguration": { "maxmemory-policy": "allkeys-lru" }
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2023-05-01",
      "name": "[variables('acaEnvName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]",
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ],
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName')), '2022-10-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName')), '2022-10-01').primarySharedKey]"
          }
        },
        "vnetConfiguration": {
          "internal": false,
          "infrastructureSubnetId": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), variables('subnetName'))]",
          "dockerBridgeCidr": "10.0.4.0/24",
          "platformReservedCidr": "10.0.5.0/24",
          "platformReservedDnsIP": "10.0.5.2"
        }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "[variables('apiAppName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', variables('acaEnvName'))]",
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]",
        "[resourceId('Microsoft.Cache/redis', variables('redisName'))]"
      ],
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('acaEnvName'))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 8000,
            "transport": "http",
            "traffic": [{ "weight": 100, "latestRevision": true }],
            "allowInsecure": true
          },
          "secrets": [
            { "name": "db-pwd", "value": "[parameters('dbAdminPassword')]" },
            { "name": "openai-key", "value": "[parameters('openAiApiKey')]" }
          ]
        },
        "template": {
          "containers": [{
            "name": "api",
            "image": "[concat(reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer, '/deepaudit:latest')]",
            "resources": {
              "cpu": "[float(parameters('containerCpu'))]",
              "memory": "[parameters('containerMemory')]"
            },
            "command": ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"],
            "env": [
              { "name": "LOG_LEVEL", "value": "INFO" },
              { "name": "REPO_STORAGE_PATH", "value": "/tmp/deepaudit/repos" },
              { "name": "MAX_REPO_SIZE_MB", "value": "500" },
              { "name": "DEFAULT_LLM_PROVIDER", "value": "openai" },
              { "name": "DEFAULT_LLM_MODEL", "value": "gpt-4o-mini" },
              {
                "name": "DATABASE_URL",
                "value": "[concat('postgresql+asyncpg://', parameters('dbAdminLogin'), ':', parameters('dbAdminPassword'), '@', reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))).fullyQualifiedDomainName, ':5432/', parameters('dbName'))]"
              },
              {
                "name": "REDIS_URL",
                "value": "[concat('rediss://', reference(resourceId('Microsoft.Cache/redis', variables('redisName'))).hostName, ':6380/0')]"
              },
              { "name": "OPENAI_API_KEY", "secretRef": "openai-key" }
            ]
          }],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 3,
            "rules": [{
              "name": "http",
              "http": { "metadata": { "concurrentRequests": "10" }, "auth": [] }
            }]
          }
        }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "[variables('workerAppName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', variables('acaEnvName'))]",
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]",
        "[resourceId('Microsoft.Cache/redis', variables('redisName'))]"
      ],
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('acaEnvName'))]",
        "configuration": {
          "secrets": [
            { "name": "db-pwd", "value": "[parameters('dbAdminPassword')]" },
            { "name": "openai-key", "value": "[parameters('openAiApiKey')]" }
          ]
        },
        "template": {
          "containers": [{
            "name": "worker",
            "image": "[concat(reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer, '/deepaudit:latest')]",
            "resources": {
              "cpu": "[float(parameters('containerCpu'))]",
              "memory": "[parameters('containerMemory')]"
            },
            "command": ["arq", "app.workers.audit_worker.WorkerSettings"],
            "env": [
              { "name": "LOG_LEVEL", "value": "INFO" },
              { "name": "REPO_STORAGE_PATH", "value": "/tmp/deepaudit/repos" },
              { "name": "MAX_REPO_SIZE_MB", "value": "500" },
              { "name": "DEFAULT_LLM_PROVIDER", "value": "openai" },
              { "name": "DEFAULT_LLM_MODEL", "value": "gpt-4o-mini" },
              {
                "name": "DATABASE_URL",
                "value": "[concat('postgresql+asyncpg://', parameters('dbAdminLogin'), ':', parameters('dbAdminPassword'), '@', reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))).fullyQualifiedDomainName, ':5432/', parameters('dbName'))]"
              },
              {
                "name": "REDIS_URL",
                "value": "[concat('rediss://', reference(resourceId('Microsoft.Cache/redis', variables('redisName'))).hostName, ':6380/0')]"
              },
              { "name": "OPENAI_API_KEY", "secretRef": "openai-key" }
            ]
          }],
          "scale": { "minReplicas": 1, "maxReplicas": 2 }
        }
      }
    }
  ],
  "outputs": {
    "apiUrl": {
      "type": "string",
      "value": "[concat('https://', reference(resourceId('Microsoft.App/containerApps', variables('apiAppName'))).properties.configuration.ingress.fqdn)]"
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer]"
    },
    "postgresFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))).fullyQualifiedDomainName]"
    },
    "redisHostName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Cache/redis', variables('redisName'))).hostName]"
    }
  }
}
