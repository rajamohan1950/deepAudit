# Database
DATABASE_URL=postgresql+asyncpg://deepaudit:deepaudit@localhost:5432/deepaudit

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM API Keys (at least one required)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Default LLM model
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# API server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# File storage for cloned repos
REPO_STORAGE_PATH=/tmp/deepaudit/repos
MAX_REPO_SIZE_MB=500

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Audit settings
MAX_CONCURRENT_PHASES=3
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=120

# GitHub App (optional, for private repos via app installation)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
